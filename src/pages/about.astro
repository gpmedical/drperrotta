---
import SiteLayout from '../layouts/SiteLayout.astro';
import { defaultLocale } from '../i18n/config';
import { getMessages } from '../i18n/messages';

const locale = defaultLocale;
const messages = getMessages(locale);
const about = messages.about;

const icons = {
	arrow: ['M3 8h9M8.5 4.5 12 8l-3.5 3.5'],
	download: ['M8 3v7M5.5 7.5 8 10l2.5-2.5', 'M4 13h8'],
	check: ['m4 9 2.5 2.5L12 6'],
	globe: [
		'M8 14A6 6 0 1 0 8 2a6 6 0 0 0 0 12Z',
		'M2.5 8h11',
		'M8 2c1.5 1.7 2.2 3.7 2.2 6S9.5 12.3 8 14c-1.5-1.7-2.2-3.7-2.2-6S6.5 3.7 8 2Z',
	],
	award: ['M8 10a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z', 'm5.8 9.4-.8 4 3-1.7 3 1.7-.8-4'],
	cap: ['M2 6.5 8 4l6 2.5L8 9 2 6.5Z', 'M5 8v3c1.5 1.1 4.5 1.1 6 0V8'],
	certificate: ['M5 3h6l2 2v8H5V3Z', 'M10.8 3v2.8h2.8', 'M7 8h4M7 10.5h3'],
	users: ['M6.5 8.5a2.2 2.2 0 1 0 0-4.4 2.2 2.2 0 0 0 0 4.4Z', 'M3 13c.5-1.8 1.8-2.8 3.5-2.8S9.5 11.2 10 13', 'M11 8.4a2 2 0 1 0 0-4', 'M11 10.3c1.4.1 2.5 1 3 2.7'],
} as const;

type IconName = keyof typeof icons;

const credentialIcons: IconName[] = ['cap', 'certificate', 'users'];
---

<SiteLayout
	locale={locale}
	currentPath="/about"
	title={about.metadata.title}
	description={about.metadata.description}
>
	<section class="about-hero" aria-labelledby="about-hero-title">
		<div class="about-hero-grid page-grid">
			<div class="hero-copy">
				<div class="hero-badges" aria-label="Professional profile">
					{
						about.hero.badges.map((badge, index) => (
							<span>
								<svg viewBox="0 0 16 16" aria-hidden="true">
									{icons[index === 0 ? 'check' : 'globe'].map((path) => <path d={path}></path>)}
								</svg>
								{badge}
							</span>
						))
					}
				</div>
				<h1 id="about-hero-title">
					<span>{about.hero.title.lineOne}</span>
					<span>{about.hero.title.lineTwo}</span>
					<span class="accent-line">{about.hero.title.lineThree}</span>
					<span class="accent-line">{about.hero.title.lineFour}</span>
				</h1>
				<p>{about.hero.description}</p>
				<div class="hero-actions">
					<a href="/contact" class="button button-primary">
						{about.hero.primaryCta}
						<svg viewBox="0 0 16 16" aria-hidden="true">
							{icons.arrow.map((path) => <path d={path}></path>)}
						</svg>
					</a>
					<a href="#career" class="button button-secondary">
						{about.hero.secondaryCta}
						<svg viewBox="0 0 16 16" aria-hidden="true">
							{icons.download.map((path) => <path d={path}></path>)}
						</svg>
					</a>
				</div>
			</div>

			<figure class="hero-portrait">
				<img src={about.hero.image} alt={about.hero.imageAlt} loading="eager" />
			</figure>
		</div>
	</section>

	<section class="bio-section" aria-labelledby="bio-title">
		<div class="bio-grid page-grid">
			<div>
				<h2 id="bio-title">
					<span>{about.biography.titleLineOne}</span>
					<span>{about.biography.titleLineTwo}</span>
				</h2>
			</div>
			<div class="bio-copy">
				{about.biography.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
			</div>
		</div>
	</section>

	<section class="career-section" id="career" aria-labelledby="career-title">
		<div class="page-grid">
			<div class="section-heading">
				<h2 id="career-title">{about.career.title}</h2>
				<p>{about.career.description}</p>
			</div>

			<div class="timeline">
				{
					about.career.items.map((item, index) => (
						<article class:list={['timeline-item', index % 2 === 0 ? 'left' : 'right']}>
							<span class="timeline-marker" aria-hidden="true">
								<svg viewBox="0 0 16 16">
									{icons[index === 0 ? 'award' : index === 1 ? 'arrow' : 'certificate'].map((path) => (
										<path d={path}></path>
									))}
								</svg>
							</span>
							<div class="timeline-card">
								<p class="timeline-period">{item.period}</p>
								<h3>{item.title}</h3>
								<p class="timeline-location">{item.location}</p>
								<p>{item.description}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="credentials-section" aria-label="Education, certifications, and memberships">
		<div class="credentials-grid page-grid">
			{
				about.credentials.map((group, index) => (
					<article class="credential-card">
						<span class="credential-icon" aria-hidden="true">
							<svg viewBox="0 0 16 16">
								{icons[credentialIcons[index]].map((path) => <path d={path}></path>)}
							</svg>
						</span>
						<h2>{group.title}</h2>
						<ul>
							{
								group.items.map((item) => (
									<li>
										<span class="list-dot" aria-hidden="true"></span>
										<span>
											<strong>{item.label}</strong>
											{item.detail && <small>{item.detail}</small>}
										</span>
									</li>
								))
							}
						</ul>
					</article>
				))
			}
		</div>
	</section>

	<section class="about-cta">
		<div class="cta-inner page-grid">
			<div>
				<h2>{about.cta.title}</h2>
				<p>{about.cta.description}</p>
			</div>
			<div class="cta-actions">
				<a href="/contact" class="button cta-primary">{about.cta.primary}</a>
				<a href="/contact" class="button cta-secondary">{about.cta.secondary}</a>
			</div>
		</div>
	</section>
</SiteLayout>

<style>
	:global(:root) {
		--about-accent: var(--accent);
		--about-accent-hover: #0878dc;
		--about-accent-dark: var(--accent-dark);
		--about-accent-soft: #eaf4ff;
		--about-surface: var(--surface);
		--about-surface-soft: #f4f6f8;
		--about-surface-muted: #f3f5f7;
		--about-border: #dfe6ee;
		--about-text: #0f172a;
		--about-muted: #667085;
		--about-focus-ring: 0 0 0 3px rgba(20, 127, 232, 0.24);
	}

	.page-grid {
		width: min(calc(100% - 48px), 900px);
		margin: 0 auto;
	}

	.about-hero {
		padding: 75px 0 72px;
		background: var(--about-surface);
	}

	.about-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
		align-items: center;
		gap: 86px;
		animation: fade-up 520ms ease both;
	}

	.hero-copy {
		max-width: 420px;
	}

	.hero-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: 22px;
	}

	.hero-badges span {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		min-height: 20px;
		padding: 4px 8px;
		border-radius: 999px;
		background: var(--about-accent-soft);
		color: var(--about-accent);
		font-size: 0.68rem;
		font-weight: 700;
		line-height: 1;
	}

	.hero-badges svg {
		width: 12px;
		height: 12px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.hero-copy h1 {
		margin: 0 0 24px;
		color: #08111f;
		font-size: clamp(3.15rem, 5.8vw, 4.1rem);
		font-weight: 800;
		letter-spacing: 0;
		line-height: 0.94;
	}

	.hero-copy h1 span {
		display: block;
	}

	.hero-copy .accent-line {
		color: var(--about-accent);
	}

	.hero-copy > p {
		max-width: 395px;
		margin-bottom: 34px;
		color: #536174;
		font-size: 0.95rem;
		line-height: 1.62;
	}

	.hero-actions,
	.cta-actions {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 44px;
		padding: 0 22px;
		border-radius: 7px;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.button svg {
		width: 15px;
		height: 15px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.button-primary {
		background: var(--about-accent);
		color: var(--about-surface);
		box-shadow: 0 8px 15px rgba(1, 67, 121, 0.3);
	}

	.button-primary:hover,
	.button-primary:focus-visible {
		background: var(--about-accent-hover);
		color: var(--about-surface);
		box-shadow: 0 12px 22px rgba(1, 67, 121, 0.32);
		transform: translateY(-2px);
	}

	.button-secondary {
		border: 1px solid var(--about-border);
		background: var(--about-surface);
		color: #344054;
	}

	.button-secondary:hover,
	.button-secondary:focus-visible {
		border-color: #bcd7f3;
		background: #f8fbff;
		color: var(--about-accent-dark);
		transform: translateY(-2px);
	}

	.button:focus-visible {
		outline: 2px solid var(--about-accent);
		outline-offset: 3px;
		box-shadow: var(--about-focus-ring);
	}

	.hero-portrait {
		overflow: hidden;
		margin: 0;
		border: 1px solid rgba(2, 19, 32, 0.28);
		border-radius: 14px;
		background: #0d4e50;
		box-shadow: 0 24px 38px rgba(15, 34, 62, 0.25);
		transition:
			box-shadow 220ms ease,
			transform 220ms ease;
	}

	.hero-portrait:hover {
		box-shadow: 0 30px 52px rgba(15, 34, 62, 0.28);
		transform: translateY(-4px);
	}

	.hero-portrait img {
		display: block;
		width: 100%;
		aspect-ratio: 0.8;
		object-fit: cover;
		object-position: center;
		transition: transform 700ms ease;
	}

	.hero-portrait:hover img {
		transform: scale(1.025);
	}

	.bio-section {
		padding: 65px 0 68px;
		background: var(--about-surface-muted);
	}

	.bio-grid {
		display: grid;
		grid-template-columns: 260px minmax(0, 1fr);
		gap: 70px;
	}

	.bio-grid h2 {
		display: inline-block;
		position: relative;
		margin: 0;
		color: #08111f;
		font-size: 1.65rem;
		font-weight: 800;
		line-height: 1.15;
	}

	.bio-grid h2::after {
		position: absolute;
		bottom: -16px;
		left: 0;
		width: 72px;
		height: 3px;
		border-radius: 999px;
		background: var(--about-accent);
		content: '';
	}

	.bio-grid h2 span {
		display: block;
	}

	.bio-grid h2 span:last-child {
		color: var(--about-accent);
	}

	.bio-copy {
		max-width: 610px;
	}

	.bio-copy p {
		margin-bottom: 24px;
		color: #48576a;
		font-size: 0.94rem;
		line-height: 1.66;
	}

	.bio-copy p:last-child {
		margin-bottom: 0;
	}

	.career-section {
		padding: 76px 0 78px;
		background: var(--about-surface);
	}

	.section-heading {
		margin-bottom: 62px;
		text-align: center;
	}

	.section-heading h2 {
		margin-bottom: 14px;
		color: #08111f;
		font-size: 1.8rem;
		font-weight: 800;
		line-height: 1.1;
	}

	.section-heading p {
		margin: 0;
		color: var(--about-muted);
		font-size: 0.86rem;
	}

	.timeline {
		position: relative;
		display: grid;
		gap: 46px;
		max-width: 760px;
		margin: 0 auto;
	}

	.timeline::before {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 1px;
		background: #cbd9e8;
		content: '';
		transform: translateX(-50%);
	}

	.timeline-item {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		min-height: 152px;
	}

	.timeline-card {
		position: relative;
		max-width: 390px;
		padding: 24px;
		border: 1px solid #e4eaf1;
		border-radius: 10px;
		background: var(--about-surface);
		box-shadow: 0 8px 20px rgba(16, 30, 54, 0.035);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.timeline-card:hover {
		border-color: #c7ddf5;
		box-shadow: 0 16px 30px rgba(16, 30, 54, 0.08);
		transform: translateY(-3px);
	}

	.timeline-item.left .timeline-card {
		grid-column: 1;
		justify-self: start;
	}

	.timeline-item.right .timeline-card {
		grid-column: 2;
		justify-self: end;
	}

	.timeline-marker {
		position: absolute;
		top: 50%;
		left: 50%;
		z-index: 2;
		display: grid;
		width: 24px;
		height: 24px;
		place-items: center;
		border: 5px solid #e9f4ff;
		border-radius: 999px;
		background: var(--about-accent);
		color: #fff;
		box-shadow: 0 8px 18px rgba(20, 127, 232, 0.22);
		transform: translate(-50%, -50%);
	}

	.timeline-marker svg {
		width: 12px;
		height: 12px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.timeline-period {
		margin: 0 0 6px;
		color: var(--about-accent);
		font-size: 0.72rem;
		font-weight: 800;
	}

	.timeline-card h3 {
		margin: 0 0 8px;
		color: #101828;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.2;
	}

	.timeline-location {
		margin: 0 0 14px;
		color: #667085;
		font-size: 0.78rem;
	}

	.timeline-card p:last-child {
		margin: 0;
		color: #536174;
		font-size: 0.78rem;
		line-height: 1.42;
	}

	.credentials-section {
		padding: 63px 0;
		background: var(--about-surface-muted);
	}

	.credentials-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 24px;
	}

	.credential-card {
		min-height: 352px;
		padding: 32px 28px 28px;
		border: 1px solid #e5eaf0;
		border-radius: 9px;
		background: var(--about-surface);
		box-shadow: 0 8px 18px rgba(16, 30, 54, 0.03);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.credential-card:hover {
		border-color: #c7ddf5;
		box-shadow: 0 16px 30px rgba(16, 30, 54, 0.08);
		transform: translateY(-3px);
	}

	.credential-icon {
		display: grid;
		width: 42px;
		height: 42px;
		margin-bottom: 32px;
		place-items: center;
		border-radius: 50%;
		background: var(--about-accent-soft);
		color: var(--about-accent);
	}

	.credential-icon svg {
		width: 19px;
		height: 19px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.credential-card h2 {
		margin-bottom: 18px;
		color: #101828;
		font-size: 1.08rem;
		font-weight: 800;
		line-height: 1.2;
	}

	.credential-card ul {
		display: grid;
		gap: 16px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.credential-card li {
		display: grid;
		grid-template-columns: 9px 1fr;
		gap: 10px;
		color: #243245;
		font-size: 0.86rem;
		line-height: 1.3;
	}

	.list-dot {
		width: 5px;
		height: 5px;
		margin-top: 8px;
		border-radius: 50%;
		background: var(--about-accent);
	}

	.credential-card strong,
	.credential-card small {
		display: block;
	}

	.credential-card strong {
		font-weight: 500;
	}

	.credential-card small {
		margin-top: 2px;
		color: var(--about-muted);
		font-size: 0.75rem;
		line-height: 1.25;
	}

	.about-cta {
		padding: 74px 0 78px;
		background: var(--about-surface);
	}

	.cta-inner {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 32px;
		padding: 42px 48px;
		overflow: hidden;
		border-radius: 11px;
		background:
			radial-gradient(circle at 0 100%, rgba(7, 90, 168, 0.28) 0 0, transparent 190px),
			linear-gradient(135deg, #147fe8 0%, #1687f2 54%, #0d7ce9 100%);
		color: #fff;
		box-shadow: 0 14px 28px rgba(20, 127, 232, 0.2);
	}

	.cta-inner h2 {
		margin-bottom: 12px;
		color: #fff;
		font-size: 1.65rem;
		font-weight: 800;
		line-height: 1.15;
	}

	.cta-inner p {
		max-width: 560px;
		margin: 0;
		color: rgba(255, 255, 255, 0.92);
		font-size: 0.93rem;
		line-height: 1.48;
	}

	.cta-actions {
		flex-direction: column;
		align-items: stretch;
		min-width: 190px;
	}

	.cta-primary {
		min-height: 45px;
		background: #fff;
		color: var(--about-accent-dark);
	}

	.cta-primary:hover,
	.cta-primary:focus-visible {
		color: var(--about-accent-dark);
		transform: translateY(-2px);
	}

	.cta-secondary {
		min-height: 45px;
		border: 1px solid rgba(255, 255, 255, 0.25);
		background: rgba(255, 255, 255, 0.04);
		color: #fff;
	}

	.cta-secondary:hover,
	.cta-secondary:focus-visible {
		border-color: rgba(255, 255, 255, 0.5);
		color: #fff;
		transform: translateY(-2px);
	}

	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(10px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			scroll-behavior: auto !important;
			transition-duration: 0.01ms !important;
		}
	}

	@media (max-width: 820px) {
		.about-hero-grid,
		.bio-grid,
		.cta-inner {
			grid-template-columns: 1fr;
		}

		.about-hero-grid {
			gap: 40px;
		}

		.hero-copy {
			max-width: 100%;
		}

		.hero-copy > p {
			max-width: 560px;
		}

		.hero-portrait {
			width: min(100%, 420px);
		}

		.bio-grid {
			gap: 42px;
		}

		.credentials-grid {
			grid-template-columns: 1fr;
		}

		.credential-card {
			min-height: auto;
		}

		.cta-actions {
			flex-direction: row;
			min-width: 0;
		}
	}

	@media (max-width: 620px) {
		.page-grid {
			width: min(calc(100% - 32px), 900px);
		}

		.about-hero {
			padding: 48px 0 58px;
		}

		.about-hero-grid {
			display: block;
		}

		.hero-copy,
		.hero-actions,
		.hero-copy > p {
			width: 100%;
			min-width: 0;
			max-width: 100%;
		}

		.hero-copy h1 {
			font-size: clamp(2.55rem, 13vw, 3.3rem);
		}

		.hero-actions,
		.cta-actions {
			align-items: stretch;
			flex-direction: column;
		}

		.button {
			width: 100%;
			min-height: 48px;
		}

		.hero-portrait {
			width: 100%;
			margin-top: 40px;
		}

		.bio-section,
		.career-section,
		.credentials-section,
		.about-cta {
			padding: 56px 0;
		}

		.timeline {
			gap: 24px;
			max-width: 100%;
			margin: 0;
		}

		.timeline::before {
			left: 12px;
		}

		.timeline-item {
			grid-template-columns: 1fr;
			min-height: auto;
