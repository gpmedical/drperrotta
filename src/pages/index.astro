---
import SiteLayout from '../layouts/SiteLayout.astro';
import { defaultLocale } from '../i18n/config';
import { getMessages } from '../i18n/messages';

const locale = defaultLocale;
const messages = getMessages(locale);
const home = messages.home;

const accreditations = [
	{ label: 'NHS', icon: 'cross' },
	{ label: 'SICCR', icon: 'briefcase' },
	{ label: 'GMC', icon: 'shield' },
	{ label: 'SICE', icon: 'clipboard' },
];

const conditions = [
	{ ...home.conditions.items[0], icon: 'colon' },
	{ ...home.conditions.items[1], icon: 'target' },
	{ ...home.conditions.items[2], icon: 'cells' },
	{ ...home.conditions.items[3], icon: 'chart' },
	{ ...home.conditions.items[4], icon: 'colon' },
	{ ...home.conditions.items[5], icon: 'asterisk' },
];

const expertiseCards = home.about.cards.map((card, index) => ({
	...card,
	icon: index === 0 ? 'scope' : 'shield',
}));

const icons = {
	cross: '<path d="M5 4h10v12H5zM10 7v6M7 10h6"></path>',
	briefcase: '<path d="M4 7h12v8H4zM8 7V5h4v2M4 10h12"></path>',
	shield: '<path d="M10 3 15 5v4.5c0 3-2 5.4-5 7-3-1.6-5-4-5-7V5l5-2Z"></path>',
	clipboard: '<path d="M7 4h6v3H7zM6 6H5v10h10V6h-1M8 10h4M8 13h4"></path>',
	scope: '<path d="M10 4v12M6.5 7.5h7M7 12.5h6M5 16h10"></path>',
	colon:
		'<path d="M10 5c2.6 0 4 1.4 4 3.3 0 1.5-.9 2.6-2.4 3 .7.5 1.1 1.2 1.1 2.1 0 1.6-1.2 2.8-3.2 2.8H7V13h2.2c.8 0 1.2-.3 1.2-.9s-.5-.9-1.4-.9H7V8h2.7c.8 0 1.2-.3 1.2-.9S10.5 6 9.7 6H7V5h3Z"></path>',
	target:
		'<path d="M10 16a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z"></path><path d="M10 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"></path>',
	cells: '<path d="M6 7h3v3H6zM11 7h3v3h-3zM8.5 12h3v3h-3z"></path>',
	chart: '<path d="M5 14h10M6.5 12V8M10 12V5M13.5 12V9"></path>',
	asterisk: '<path d="M10 4v12M4.8 7l10.4 6M15.2 7 4.8 13"></path>',
} as const;
---

<SiteLayout locale={locale} currentPath="/">
	<section class="hero-section" aria-labelledby="hero-title">
		<div class="hero-card" style={`--hero-image: url('${home.images.hero}')`}>
			<div class="hero-overlay"></div>
			<div class="hero-content">
				<p class="hero-eyebrow">
					<span aria-hidden="true"></span>
					{home.hero.eyebrow}
				</p>
				<h1 id="hero-title">{home.hero.title}</h1>
				<p class="hero-description">{home.hero.description}</p>
				<div class="hero-actions">
					<a href="/contact" class="button button-primary">
						{home.hero.primaryCta}
						<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9M8.5 4.5 12 8l-3.5 3.5"></path></svg>
					</a>
					<a href="/about" class="button button-secondary">
						<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 14A6 6 0 1 0 8 2a6 6 0 0 0 0 12Z"></path><path d="m7 5 4 3-4 3V5Z"></path></svg>
						{home.hero.secondaryCta}
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="accreditation-strip" aria-label="Professional accreditations">
		<div class="strip-inner">
			{
				accreditations.map((item) => (
					<div class="accreditation-item">
						<span class="mini-icon" data-icon={item.icon} aria-hidden="true">
							<svg viewBox="0 0 20 20">
								<Fragment set:html={icons[item.icon]} />
							</svg>
						</span>
						<span>{item.label}</span>
					</div>
				))
			}
		</div>
	</section>

	<section class="about-section" aria-labelledby="about-title">
		<div class="about-grid page-grid">
			<div class="about-copy">
				<p class="section-kicker"><span></span>{home.about.kicker}</p>
				<h2 id="about-title">{home.about.title}</h2>
				<p>{home.about.body}</p>
				<div class="expertise-cards">
					{
						expertiseCards.map((card) => (
							<article class="expertise-card">
								<span class="card-icon" aria-hidden="true">
									<svg viewBox="0 0 20 20">
										<Fragment set:html={icons[card.icon]} />
									</svg>
								</span>
								<h3>{card.title}</h3>
								<p>{card.description}</p>
							</article>
						))
					}
				</div>
				<a href="/about" class="text-link">
					{home.about.linkLabel}
					<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9M8.5 4.5 12 8l-3.5 3.5"></path></svg>
				</a>
			</div>

			<figure class="portrait-card">
				<img src={home.images.portrait} alt="Portrait of Dr. Gerardo Perrotta" loading="lazy" />
				<figcaption>{home.about.quote}</figcaption>
			</figure>
		</div>
	</section>

	<section class="presence-section" aria-labelledby="presence-title">
		<div class="page-grid">
			<div class="section-heading centered">
				<h2 id="presence-title">{home.presence.title}</h2>
				<p>{home.presence.description}</p>
			</div>
			<div class="location-grid">
				{
					home.presence.locations.map((location) => (
						<article class="location-card">
							<div class="location-image">
								<img src={location.image} alt={`${location.city} skyline`} loading="lazy" />
								<span>{location.country}</span>
							</div>
							<div class="location-body">
								<h3>
									<svg viewBox="0 0 20 20" aria-hidden="true">
										<path d="M10 18s5-4.7 5-9a5 5 0 1 0-10 0c0 4.3 5 9 5 9Z"></path>
										<circle cx="10" cy="9" r="1.7"></circle>
									</svg>
									{location.city}
								</h3>
								<p>{location.clinic}</p>
								<p>{location.address}</p>
								<p>{location.postalCode}</p>
								<a href={location.mapUrl} target="_blank" rel="noreferrer">{location.mapLabel}</a>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="conditions-section" aria-labelledby="conditions-title">
		<div class="page-grid">
			<div class="conditions-heading">
				<div>
					<h2 id="conditions-title">{home.conditions.title}</h2>
					<p>{home.conditions.description}</p>
				</div>
				<a href="/treatments" class="text-link">
					{home.conditions.linkLabel}
					<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9M8.5 4.5 12 8l-3.5 3.5"></path></svg>
				</a>
			</div>

			<div class="condition-grid">
				{
					conditions.map((condition) => (
						<a href="/treatments" class="condition-card">
							<span class="condition-icon" data-icon={condition.icon} aria-hidden="true">
								<svg viewBox="0 0 20 20">
									<Fragment set:html={icons[condition.icon]} />
								</svg>
							</span>
							<span>
								<strong>{condition.title}</strong>
								<small>{condition.description}</small>
							</span>
							<svg class="condition-arrow" viewBox="0 0 16 16" aria-hidden="true"><path d="m6 4 4 4-4 4"></path></svg>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="cta-section">
		<div class="cta-inner">
			<h2>{home.cta.title}</h2>
			<p>{home.cta.description}</p>
			<div class="cta-actions">
				<a href="/contact" class="button cta-primary">
					{home.cta.primary}
					<svg viewBox="0 0 20 20" aria-hidden="true"><rect x="4" y="5" width="12" height="11" rx="2"></rect><path d="M7 3v4M13 3v4M4 9h12"></path></svg>
				</a>
				<a href="/contact" class="button cta-secondary">{home.cta.secondary}</a>
			</div>
		</div>
	</section>
</SiteLayout>

<style>
	.page-grid {
		width: min(100% - 48px, 1200px);
		margin: 0 auto;
	}

	.hero-section {
		padding: 0;
		background: #fff;
	}

	.hero-card {
		position: relative;
		display: grid;
		align-items: center;
		width: min(100% - 48px, 1200px);
		min-height: 520px;
		margin: 0 auto;
		overflow: hidden;
		border: 1px solid rgba(2, 19, 32, 0.18);
		border-radius: 12px;
		background:
			linear-gradient(90deg, rgba(2, 28, 39, 0.92) 0%, rgba(4, 66, 85, 0.72) 40%, rgba(4, 45, 62, 0.2) 100%),
			var(--hero-image) center / cover;
		box-shadow: 0 14px 24px rgba(16, 30, 54, 0.18);
		animation: fade-up 520ms ease both;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(8, 109, 151, 0.22), rgba(1, 16, 28, 0.45));
	}

	.hero-content {
		position: relative;
		z-index: 1;
		width: min(610px, 72%);
		padding: 76px 0 76px 64px;
		color: #fff;
	}

	.hero-eyebrow,
	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin: 0 0 20px;
		color: #e9f5ff;
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1;
		text-transform: uppercase;
	}

	.hero-eyebrow {
		padding: 8px 13px;
		border-radius: 999px;
		background: rgba(64, 149, 216, 0.58);
	}

	.hero-eyebrow span {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: #dff1ff;
	}

	.hero-content h1 {
		max-width: 590px;
		margin-bottom: 24px;
		color: #fff;
		font-size: clamp(2.65rem, 4.35vw, 3.6rem);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
	}

	.hero-description {
		max-width: 590px;
		margin-bottom: 30px;
		color: rgba(255, 255, 255, 0.95);
		font-size: 1.05rem;
		line-height: 1.45;
	}

	.hero-actions,
	.cta-actions {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 46px;
		padding: 0 24px;
		border-radius: 8px;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.button svg,
	.text-link svg {
		width: 16px;
		height: 16px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.button-primary {
		background: #1687f2;
		color: #fff;
		box-shadow: 0 8px 15px rgba(1, 67, 121, 0.3);
	}

	.button-primary:hover {
		background: #0878dc;
		color: #fff;
		transform: translateY(-2px);
		box-shadow: 0 12px 22px rgba(1, 67, 121, 0.32);
	}

	.button-secondary {
		border: 1px solid rgba(255, 255, 255, 0.35);
		background: rgba(5, 18, 31, 0.52);
		color: #fff;
		backdrop-filter: blur(8px);
	}

	.button-secondary:hover {
		border-color: rgba(255, 255, 255, 0.56);
		color: #fff;
		transform: translateY(-2px);
	}

	.accreditation-strip {
		border-bottom: 1px solid #e3e8ef;
		background: #fff;
	}

	.strip-inner {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		width: min(100% - 80px, 1100px);
		min-height: 92px;
		margin: 0 auto;
		align-items: center;
	}

	.accreditation-item {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 9px;
		color: #b6bec8;
		font-size: 1rem;
		font-weight: 600;
	}

	.mini-icon {
		display: grid;
		width: 20px;
		height: 20px;
		place-items: center;
		color: #b6bec8;
	}

	.mini-icon svg {
		width: 18px;
		height: 18px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.9;
	}

	.about-section {
		padding: 96px 0 88px;
		background: linear-gradient(90deg, #f7f9fc 0%, #f3f6fa 52%, #eef3f8 100%);
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(420px, 570px);
		align-items: center;
		gap: 64px;
	}

	.section-kicker {
		margin-bottom: 28px;
		color: #1687f2;
	}

	.section-kicker span {
		width: 31px;
		height: 2px;
		border-radius: 999px;
		background: #8bbef0;
	}

	.about-copy h2 {
		max-width: 560px;
		margin-bottom: 22px;
		color: #050b16;
		font-size: clamp(2.35rem, 3.4vw, 3.1rem);
		line-height: 1.02;
	}

	.about-copy > p {
		max-width: 590px;
		color: #6a778b;
		font-size: 1rem;
		line-height: 1.7;
	}

	.expertise-cards {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
		max-width: 570px;
		margin-top: 34px;
	}

	.expertise-card {
		min-height: 148px;
		padding: 22px 20px;
		border: 1px solid #dfe6ee;
		border-radius: 10px;
		background: #fff;
		box-shadow: 0 8px 16px rgba(16, 30, 54, 0.04);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.expertise-card:hover {
		border-color: #c7ddf5;
		box-shadow: 0 16px 30px rgba(16, 30, 54, 0.08);
		transform: translateY(-3px);
	}

	.card-icon,
	.condition-icon {
		display: grid;
		width: 36px;
		height: 36px;
		place-items: center;
		border-radius: 8px;
		background: #eaf4ff;
		color: #1687f2;
	}

	.card-icon svg,
	.condition-icon svg {
		width: 18px;
		height: 18px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.expertise-card h3 {
		margin: 16px 0 7px;
		color: #111827;
		font-size: 1rem;
		font-weight: 700;
	}

	.expertise-card p {
		margin: 0;
		color: #6a778b;
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.text-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin-top: 42px;
		color: #1687f2;
		font-size: 0.9rem;
		font-weight: 700;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.text-link:hover {
		color: #075aa8;
		transform: translateX(3px);
	}

	.portrait-card {
		position: relative;
		overflow: hidden;
		margin: 0;
		border-radius: 22px;
		background: #fff;
		box-shadow: 0 20px 32px rgba(15, 34, 62, 0.24);
		transition:
			box-shadow 220ms ease,
			transform 220ms ease;
	}

	.portrait-card:hover {
		box-shadow: 0 28px 50px rgba(15, 34, 62, 0.28);
		transform: translateY(-4px);
	}

	.portrait-card::after {
		position: absolute;
		inset: auto 0 0;
		height: 36%;
		background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.66));
		content: '';
	}

	.portrait-card img {
		display: block;
		width: 100%;
		aspect-ratio: 1.14;
		object-fit: cover;
		object-position: center 18%;
		transition: transform 700ms ease;
	}

	.portrait-card:hover img {
		transform: scale(1.035);
	}

	.portrait-card figcaption {
		position: absolute;
		right: 30px;
		bottom: 30px;
		left: 30px;
		z-index: 1;
		margin: 0;
		color: #fff;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.35;
		text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
	}

	.presence-section {
		padding: 70px 0 82px;
		background: #f7f9fc;
	}

	.section-heading {
		margin-bottom: 44px;
	}

	.centered {
		text-align: center;
	}

	.section-heading h2,
	.conditions-heading h2,
	.cta-inner h2 {
		margin-bottom: 14px;
		color: #07111f;
		font-size: clamp(2rem, 3vw, 2.65rem);
		line-height: 1.05;
	}

	.section-heading p,
	.conditions-heading p {
		color: #667085;
		font-size: 1rem;
	}

	.location-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 24px;
	}

	.location-card {
		overflow: hidden;
		border: 1px solid #dfe6ee;
		border-radius: 10px;
		background: #fff;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.location-card:hover {
		border-color: #c7ddf5;
		box-shadow: 0 18px 32px rgba(16, 30, 54, 0.09);
		transform: translateY(-4px);
	}

	.location-image {
		position: relative;
		height: 180px;
		overflow: hidden;
	}

	.location-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 700ms ease;
	}

	.location-card:hover .location-image img {
		transform: scale(1.06);
	}

	.location-image span {
		position: absolute;
		top: 11px;
		right: 10px;
		padding: 5px 11px;
		border-radius: 999px;
		background: #fff;
		color: #516071;
		font-size: 0.68rem;
		font-weight: 700;
	}

	.location-body {
		padding: 18px 20px 20px;
	}

	.location-body h3 {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 0 0 14px;
		color: #111827;
		font-size: 0.96rem;
		font-weight: 700;
	}

	.location-body h3 svg {
		width: 16px;
		height: 16px;
		fill: none;
		color: #1687f2;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.location-body p {
		margin: 0 0 6px;
		color: #667085;
		font-size: 0.78rem;
		line-height: 1.28;
	}

	.location-body a {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 36px;
		margin-top: 18px;
		border: 1px solid #dbe4ee;
		border-radius: 8px;
		color: #111827;
		font-size: 0.8rem;
		font-weight: 600;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			color 180ms ease;
	}

	.location-body a:hover {
		border-color: #1687f2;
		background: #eef7ff;
		color: #075aa8;
	}

	.conditions-section {
		padding: 70px 0 62px;
		background: #f4f7fb;
	}

	.conditions-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 42px;
	}

	.conditions-heading .text-link {
		margin: 0 0 5px;
	}

	.condition-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.condition-card {
		display: grid;
		grid-template-columns: 44px 1fr 18px;
		align-items: center;
		gap: 15px;
		min-height: 74px;
		padding: 15px 17px;
		border: 1px solid #dfe6ee;
		border-radius: 10px;
		background: #fff;
		color: #111827;
		box-shadow: 0 7px 18px rgba(16, 30, 54, 0.03);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.condition-card:hover {
		border-color: #bcd7f3;
		color: #111827;
		box-shadow: 0 14px 28px rgba(16, 30, 54, 0.08);
		transform: translateY(-2px);
	}

	.condition-card strong,
	.condition-card small {
		display: block;
		line-height: 1.2;
	}

	.condition-card strong {
		margin-bottom: 4px;
		font-size: 0.9rem;
	}

	.condition-card small {
		color: #667085;
		font-size: 0.76rem;
	}

	.condition-icon {
		background: #edf3f9;
		color: #48627f;
	}

	.condition-arrow {
		width: 15px;
		height: 15px;
		fill: none;
		color: #b8c2cf;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
