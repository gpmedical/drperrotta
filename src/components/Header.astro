---
import { defaultLocale, enabledLocales, localeOptions, type Locale } from '../i18n/config';
import { getMessages, type SiteMessages } from '../i18n/messages';

interface Props {
	locale?: Locale;
	content?: SiteMessages['header'];
	currentPath?: string;
}

const {
	locale = defaultLocale,
	content = getMessages(locale).header,
	currentPath = Astro.url.pathname,
} = Astro.props;

const activeLocales = enabledLocales.join(',');

function isActive(href: string) {
	if (href === '/') {
		return currentPath === '/';
	}

	return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="site-header">
	<nav class="site-nav" aria-label="Primary navigation">
		<button
			class="menu-toggle"
			type="button"
			aria-label="Open navigation menu"
			aria-expanded="false"
			aria-controls="primary-menu"
			data-menu-toggle
		>
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M4 7h16M4 12h16M4 17h16"></path>
			</svg>
		</button>

		<a class="brand" href="/" aria-label={`${content.brand.name} home`}>
			<span class="brand-mark" aria-hidden="true">
				<svg viewBox="0 0 24 24" role="img">
					<rect x="3" y="3" width="18" height="18" rx="5"></rect>
					<path d="M12 7v10M7 12h10"></path>
				</svg>
			</span>
			<span>
				<strong>{content.brand.name}</strong>
				<small>{content.brand.title}</small>
			</span>
		</a>

		<label class="language-picker mobile-language-picker">
			<span class="sr-only">{content.languageLabel}</span>
			<select
				name="mobile-locale"
				aria-label={content.languageLabel}
				data-locale-select
				data-active-locales={activeLocales}
			>
				{
					localeOptions.map((option) => (
						<option value={option.code} selected={option.code === locale} disabled={!option.enabled}>
							{option.label}
						</option>
					))
				}
			</select>
			<svg viewBox="0 0 16 16" aria-hidden="true">
				<path d="m4 6 4 4 4-4"></path>
			</svg>
		</label>

		<a class="mobile-booking-button" href="/contact" aria-label={content.consultationLabel}>
			<svg viewBox="0 0 20 20" aria-hidden="true">
				<rect x="4" y="5" width="12" height="11" rx="2"></rect>
				<path d="M7 3v4M13 3v4M4 9h12"></path>
			</svg>
		</a>

		<div class="nav-menu" id="primary-menu" data-nav-menu>
			<div class="nav-links">
				{
					content.navigation.map((item) => (
						<a href={item.href} class:list={[{ active: isActive(item.href) }]}>
							{item.label}
						</a>
					))
				}
			</div>
		</div>

		<div class="nav-actions">
			<label class="language-picker desktop-language-picker">
				<span class="sr-only">{content.languageLabel}</span>
				<select
					name="locale"
					aria-label={content.languageLabel}
					data-locale-select
					data-active-locales={activeLocales}
				>
					{
						localeOptions.map((option) => (
							<option value={option.code} selected={option.code === locale} disabled={!option.enabled}>
								{option.label}
							</option>
						))
					}
				</select>
				<svg viewBox="0 0 16 16" aria-hidden="true">
					<path d="m4 6 4 4 4-4"></path>
				</svg>
			</label>
			<a class="booking-button" href="/contact">
				<svg viewBox="0 0 20 20" aria-hidden="true">
					<rect x="4" y="5" width="12" height="11" rx="2"></rect>
					<path d="M7 3v4M13 3v4M4 9h12"></path>
				</svg>
				<span>{content.consultationLabel}</span>
			</a>
		</div>
	</nav>
</header>

<script>
	const selects = document.querySelectorAll('[data-locale-select]');
	const header = document.querySelector('.site-header');
	const menuToggle = document.querySelector('[data-menu-toggle]');
	const navMenu = document.querySelector('[data-nav-menu]');

	if (
		header instanceof HTMLElement &&
		menuToggle instanceof HTMLButtonElement &&
		navMenu instanceof HTMLElement
	) {
		const closeMenu = () => {
			header.classList.remove('menu-open');
			menuToggle.setAttribute('aria-expanded', 'false');
			menuToggle.setAttribute('aria-label', 'Open navigation menu');
		};

		menuToggle.addEventListener('click', () => {
			const isOpen = header.classList.toggle('menu-open');
			menuToggle.setAttribute('aria-expanded', String(isOpen));
			menuToggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
		});

		navMenu.addEventListener('click', (event) => {
			if (event.target instanceof HTMLAnchorElement) {
				closeMenu();
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeMenu();
			}
		});
	}

	const primarySelect = Array.from(selects).find((select) => select instanceof HTMLSelectElement);

	if (primarySelect instanceof HTMLSelectElement) {
		const select = primarySelect;
		const enabled = (select.dataset.activeLocales ?? 'en').split(',');
		const currentLocale = select.value;
		const storedLocale = localStorage.getItem('preferredLocale');
		const browserLocale = navigator.languages?.[0]?.slice(0, 2) ?? navigator.language?.slice(0, 2);
		const preferredLocale = storedLocale ?? browserLocale;

		if (preferredLocale && enabled.includes(preferredLocale) && preferredLocale !== currentLocale) {
			const targetPath =
				preferredLocale === 'en'
					? window.location.pathname.replace(/^\/(it|en)(?=\/|$)/, '') || '/'
					: `/${preferredLocale}${window.location.pathname.replace(/^\/(it|en)(?=\/|$)/, '')}`;

			window.location.replace(targetPath + window.location.search + window.location.hash);
		}

		selects.forEach((localeSelect) => {
			if (!(localeSelect instanceof HTMLSelectElement)) {
				return;
			}

			localeSelect.addEventListener('change', () => {
				localStorage.setItem('preferredLocale', localeSelect.value);
				if (!enabled.includes(localeSelect.value)) {
					localeSelect.value = currentLocale;
					return;
				}

				const unlocalizedPath = window.location.pathname.replace(/^\/(it|en)(?=\/|$)/, '') || '/';
				const targetPath =
					localeSelect.value === 'en' ? unlocalizedPath : `/${localeSelect.value}${unlocalizedPath}`;
				window.location.assign(targetPath + window.location.search + window.location.hash);
			});
		});
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(220, 228, 238, 0.8);
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(18px);
	}

	.site-nav {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(100% - 48px, 1200px);
		min-height: 74px;
		margin: 0 auto;
		gap: 10px;
	}

	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: 1px solid #dfe6ee;
		border-radius: 8px;
		background: #fff;
		color: #0f172a;
		cursor: pointer;
		transition:
			border-color 180ms ease,
			background 180ms ease,
			color 180ms ease;
	}

	.menu-toggle:hover {
		border-color: #bcd7f3;
		background: #eef7ff;
		color: #0878dc;
	}

	.menu-toggle svg {
		width: 22px;
		height: 22px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		min-width: 240px;
		color: #0f172a;
		transition: transform 180ms ease;
	}

	.brand:hover {
		transform: translateY(-1px);
	}

	.brand-mark {
		display: grid;
		width: 32px;
		height: 32px;
		place-items: center;
		border-radius: 8px;
		background: #1687f2;
		color: #fff;
		box-shadow: 0 8px 18px rgba(20, 127, 232, 0.25);
	}

	.brand-mark svg {
		width: 19px;
		height: 19px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2.2;
	}

	.brand strong,
	.brand small {
		display: block;
		line-height: 1.1;
	}

	.brand strong {
		font-size: 1rem;
		font-weight: 700;
		color: #0f172a;
	}

	.brand small {
		margin-top: 1px;
		font-size: 0.76rem;
		color: #667085;
	}

	.nav-menu {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex: 1;
		gap: 10px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 28px;
		flex: 1;
	}

	.nav-links a {
		position: relative;
		padding: 28px 0 25px;
		font-size: 0.88rem;
		font-weight: 500;
		color: #334155;
		transition: color 180ms ease;
	}

	.nav-links a.active,
	.nav-links a:hover {
		color: #0878dc;
	}

	.nav-links a.active::after {
		position: absolute;
		right: 0;
		bottom: 18px;
		left: 0;
		height: 2px;
		border-radius: 999px;
		background: #1687f2;
		content: '';
	}

	.nav-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 14px;
		min-width: 260px;
	}

	.language-picker {
		position: relative;
		display: inline-flex;
		align-items: center;
		color: #111827;
	}

	.mobile-language-picker {
		display: none;
	}

	.mobile-booking-button {
		display: none;
	}

	.language-picker select {
		appearance: none;
		border: 0;
		background: transparent;
		padding: 8px 18px 8px 4px;
		color: #111827;
		font: inherit;
		font-size: 0.88rem;
		font-weight: 600;
		cursor: pointer;
	}

	.language-picker svg {
		position: absolute;
		right: 2px;
		width: 12px;
		height: 12px;
		fill: none;
		pointer-events: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.booking-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		min-height: 42px;
		padding: 0 16px;
		border-radius: 8px;
		background: #1687f2;
		color: #fff;
		font-size: 0.88rem;
		font-weight: 700;
		box-shadow: 0 10px 22px rgba(20, 127, 232, 0.24);
		white-space: nowrap;
		transition:
			background 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.booking-button:hover {
		background: #0878dc;
		color: #fff;
		box-shadow: 0 14px 28px rgba(20, 127, 232, 0.28);
		transform: translateY(-1px);
	}

	.booking-button svg {
		width: 15px;
		height: 15px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	@media (max-width: 560px) {
		.site-nav {
			width: min(100% - 24px, 1200px);
			min-height: 64px;
			gap: 12px;
		}

		.menu-toggle {
			display: inline-flex;
			flex: 0 0 auto;
			order: 0;
		}

		.brand {
			flex: 1;
			min-width: auto;
		}

		.mobile-language-picker {
			display: inline-flex;
			flex: 0 0 auto;
		}

		.mobile-booking-button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			flex: 0 0 auto;
			width: 40px;
			height: 40px;
			border-radius: 8px;
			background: #1687f2;
			color: #fff;
			box-shadow: 0 8px 18px rgba(20, 127, 232, 0.22);
			transition:
				background 180ms ease,
				box-shadow 180ms ease,
				transform 180ms ease;
		}

		.mobile-booking-button:hover {
			background: #0878dc;
			color: #fff;
			box-shadow: 0 12px 24px rgba(20, 127, 232, 0.28);
			transform: translateY(-1px);
		}

		.mobile-booking-button svg {
			width: 17px;
			height: 17px;
			fill: none;
			stroke: currentColor;
			stroke-linecap: round;
			stroke-linejoin: round;
			stroke-width: 1.9;
		}

		.desktop-language-picker {
			display: none;
		}

		.nav-menu {
			position: absolute;
			top: calc(100% + 1px);
			right: -12px;
			left: -12px;
			display: none;
			grid-template-columns: 1fr;
			gap: 18px;
			padding: 18px 12px 20px;
			border-bottom: 1px solid rgba(220, 228, 238, 0.95);
			background: rgba(255, 255, 255, 0.98);
			box-shadow: 0 18px 28px rgba(16, 30, 54, 0.11);
			backdrop-filter: blur(18px);
		}

		.site-header.menu-open .nav-menu {
			display: grid;
		}

		.nav-links {
			display: grid;
			grid-template-columns: 1fr;
			justify-content: flex-start;
			gap: 4px;
		}

		.nav-links a {
			padding: 11px 10px;
			border-radius: 8px;
			font-size: 1rem;
		}

		.nav-links a.active::after {
			display: none;
		}

		.nav-links a.active {
			background: #eef7ff;
		}

		.brand small {
			display: none;
		}

		.nav-actions {
			display: none;
		}

	}
</style>
