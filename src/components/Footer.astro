---
import { defaultLocale, type Locale } from '../i18n/config';
import { getMessages, type SiteMessages } from '../i18n/messages';

interface Props {
	locale?: Locale;
	content?: SiteMessages['footer'];
}

const { locale = defaultLocale, content = getMessages(locale).footer } = Astro.props;
---

<footer class="site-footer">
	<div class="footer-grid">
		<div class="footer-brand">
			<a class="brand" href="/">
				<span class="brand-mark" aria-hidden="true">
					<svg viewBox="0 0 24 24">
						<rect x="3" y="3" width="18" height="18" rx="5"></rect>
						<path d="M12 7v10M7 12h10"></path>
					</svg>
				</span>
				<span>Dr. Gerardo Perrotta</span>
			</a>
			<p>{content.description}</p>
			<div class="social-links" aria-label="Social links">
				<a href="https://twitter.com/" target="_blank" aria-label="X / Twitter">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M18 3h3l-6.5 7.4L22 21h-5.8l-4.5-5.9L6.5 21H3.4l7-8L3 3h5.9l4.1 5.5L18 3Z"></path>
					</svg>
				</a>
				<a href="https://www.linkedin.com/" target="_blank" aria-label="LinkedIn">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M6.5 8.5H3.7V21h2.8V8.5ZM5.1 3a1.65 1.65 0 1 0 0 3.3A1.65 1.65 0 0 0 5.1 3Zm15.2 11.1c0-3.4-1.8-5.1-4.3-5.1a3.7 3.7 0 0 0-3.3 1.8V8.5H10V21h2.8v-6.8c0-1.8 1-2.8 2.4-2.8 1.3 0 2.2.8 2.2 2.7V21h2.9v-6.9Z"></path>
					</svg>
				</a>
			</div>
		</div>

		<div class="footer-column">
			<h2>{content.quickLinksTitle}</h2>
			<ul>
				{content.quickLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
			</ul>
		</div>

		<div class="footer-column">
			<h2>{content.locationsTitle}</h2>
			<ul class="icon-list">
				{
					content.locations.map((location) => (
						<li>
							<svg viewBox="0 0 20 20" aria-hidden="true">
								<path d="M10 18s5-4.7 5-9a5 5 0 1 0-10 0c0 4.3 5 9 5 9Z"></path>
								<circle cx="10" cy="9" r="1.7"></circle>
							</svg>
							<a href={location.mapUrl} target="_blank" rel="noreferrer">{location.label}</a>
						</li>
					))
				}
			</ul>
		</div>

		<div class="footer-column">
			<h2>{content.contactTitle}</h2>
			<ul class="icon-list">
				{
					content.contactLines.map((line, index) => (
						<li>
							{
								index < 2 ? (
									<svg viewBox="0 0 20 20" aria-hidden="true">
										<path d="M6.8 3.5 8.6 7 6.7 8.4c.8 1.7 2.2 3.1 3.9 3.9l1.4-1.9 3.5 1.8-.8 3.4c-.1.5-.6.9-1.1.9C8 16.5 3.5 12 3.5 6.4c0-.5.4-1 .9-1.1l2.4-.8Z" />
									</svg>
								) : (
									<svg viewBox="0 0 20 20" aria-hidden="true">
										<path d="M3 5.5h14v9H3v-9Z"></path>
										<path d="m3 6 7 5 7-5"></path>
									</svg>
								)
							}
							<span>{line}</span>
						</li>
					))
				}
			</ul>
		</div>
	</div>

	<div class="footer-bottom">
		<p>{content.copyright}</p>
		<nav aria-label="Legal links">
			{content.legal.map((item) => <a href="/">{item}</a>)}
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		background: #fff;
		color: #667085;
	}

	.footer-grid,
	.footer-bottom {
		width: min(100% - 48px, 1200px);
		margin: 0 auto;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.25fr 1fr 1.35fr 1.1fr;
		gap: 56px;
		padding: 56px 0 42px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: #0f172a;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.brand-mark {
		display: grid;
		width: 24px;
		height: 24px;
		place-items: center;
		border-radius: 6px;
		background: #1687f2;
		color: #fff;
	}

	.brand-mark svg {
		width: 16px;
		height: 16px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2.2;
	}

	.footer-brand p {
		max-width: 250px;
		margin-top: 18px;
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.social-links {
		display: flex;
		gap: 16px;
		margin-top: 22px;
	}

	.social-links a {
		display: grid;
		width: 20px;
		height: 20px;
		place-items: center;
		color: #53657d;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.social-links a:hover {
		color: #1687f2;
		transform: translateY(-2px);
	}

	.social-links svg {
		width: 17px;
		height: 17px;
		fill: currentColor;
	}

	.footer-column h2 {
		margin-bottom: 16px;
		color: #101828;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.footer-column ul {
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.footer-column a,
	.footer-column li {
		color: #667085;
		font-size: 0.86rem;
		line-height: 1.35;
	}

	.footer-column a:hover {
		color: #1687f2;
	}

	.footer-column a {
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.footer-column a:hover {
		transform: translateX(2px);
	}

	.icon-list li {
		display: grid;
		grid-template-columns: 16px 1fr;
		align-items: start;
		gap: 8px;
	}

	.icon-list svg {
		width: 15px;
		height: 15px;
		margin-top: 2px;
		fill: none;
		color: #36506b;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	.footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 24px 0;
		border-top: 1px solid #e5eaf0;
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.78rem;
	}

	.footer-bottom nav {
		display: flex;
		gap: 24px;
	}

	.footer-bottom a {
		color: #667085;
		font-size: 0.78rem;
	}

	@media (max-width: 540px) {
		.footer-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 42px;
		}
	}

	@media (max-width: 440px) {
		.footer-grid,
		.footer-bottom {
			width: min(100% - 32px, 1200px);
		}

		.footer-grid {
			grid-template-columns: 1fr;
			padding: 44px 0 34px;
		}

		.footer-bottom {
			align-items: flex-start;
			flex-direction: column;
		}

		.footer-bottom nav {
			flex-wrap: wrap;
			gap: 16px;
		}
	}
</style>
